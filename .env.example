# ===========================================
# MakTime — конфигурация
# Скопируйте этот файл: cp .env.example .env
# и замените значения на свои
# ===========================================

# Секретный ключ для подписи JWT-токенов (ОБЯЗАТЕЛЬНО смените!)
# Сгенерируйте случайный ключ: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-CHANGE-ME

# Порт сервера (внутренний)
PORT=3001

# Окружение: production или development
NODE_ENV=production

# TURN-сервер для видеозвонков (coturn)
TURN_USER=maktime
TURN_PASS=MakTimeT0rn2026!
TURN_REALM=maktime.space

# --- APNs: один ключ .p8 на оба типа push (VoIP + обычные уведомления о сообщениях) ---
# Ключ .p8 из Apple Developer → Keys → APNs; смонтируй файл в контейнер и укажи путь.
# Для TestFlight/App Store: APNS_PRODUCTION=true; sandbox для чистой dev-сборки с Xcode.
# VoIP: topic = APNS_BUNDLE_ID + ".voip" (PushKit). Чат: topic = APNS_BUNDLE_ID (alert).
# Клиент регистрирует токены: POST /api/devices/voip-token и POST /api/devices/apns-token.
# APNS_KEY_PATH=/app/secrets/AuthKey_XXXXX.p8
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=YYYYYYYYYY
# APNS_BUNDLE_ID=com.maktime.app
# APNS_PRODUCTION=true
